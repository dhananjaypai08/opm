{
  "name": "opm-monorepo",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/scanner",
    "packages/cli"
  ],
  "scripts": {
    "opm": "bun run packages/cli/src/index.tsx",
    "build:contracts": "cd packages/contracts && npx hardhat compile",
    "deploy:contracts": "cd packages/contracts && npx hardhat run scripts/deploy.ts --network baseSepolia",
    "test:contracts": "cd packages/contracts && npx hardhat test",
    "scan": "bun run packages/scanner/src/index.ts"
  },
  "dependencies": {
    "@fileverse/agents": "^2.0.1",
    "@types/react": "^18.3.28",
    "chalk": "^5.4.0",
    "ethers": "^6.13.0",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "react-devtools-core": "^5.3.2",
    "tar": "^7.5.11",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
